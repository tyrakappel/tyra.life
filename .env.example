# --- Database (Neon Postgres) ---
# Pooled connection (för queries via pgbouncer)
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/db?sslmode=require"
# Direct connection (för migrations / db:push)
DATABASE_URL_UNPOOLED="postgresql://user:password@host.region.aws.neon.tech/db?sslmode=require"

# --- NextAuth (Auth.js v5) ---
# Generera: openssl rand -base64 32
AUTH_SECRET=""
# Lokalt: http://localhost:3000 — i Vercel sätts denna automatiskt till deploy-URL:n
AUTH_URL="http://localhost:3000"

# --- Email magic link (Resend) — frivilligt ---
AUTH_RESEND_KEY=""
EMAIL_FROM="Tyra Life <noreply@tyra.life>"

# --- Google OAuth (frivilligt) ---
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
